#!/usr/bin/env swift

import AppKit

let backlogFileName = "backlog.md"
let separator = "---"

struct BacklogTask {
    let lineNumber: Int
    let status: String
    let title: String
}

enum TaskViewMode {
    case active
    case completed
}

final class BacklogStore {
    private let fileURL: URL
    private var lastModificationDate: Date?

    init(fileURL: URL) {
        self.fileURL = fileURL
        self.lastModificationDate = Self.modificationDate(for: fileURL)
    }

    func loadActiveTasks() -> [BacklogTask] {
        let active = readSections().active
        lastModificationDate = Self.modificationDate(for: fileURL)

        return active.enumerated().compactMap { index, line in
            parseTask(line: line, lineNumber: index + 1)
        }
    }

    func loadCompletedTasks() -> [BacklogTask] {
        let sections = readSections()
        lastModificationDate = Self.modificationDate(for: fileURL)

        return (sections.active + sections.archive).enumerated().compactMap { index, line in
            guard let task = parseTask(line: line, lineNumber: index + 1) else {
                return nil
            }
            return task.status.lowercased() == "x" ? task : nil
        }
    }

    func hasChanged() -> Bool {
        Self.modificationDate(for: fileURL) != lastModificationDate
    }

    func addTask(_ title: String) throws {
        let cleanTitle = normalizedTitle(title)
        guard !cleanTitle.isEmpty else {
            return
        }

        var sections = readSections()
        sections.active.append("- [ ] \(cleanTitle)")
        try write(active: sections.active, archive: sections.archive)
        lastModificationDate = Self.modificationDate(for: fileURL)
    }

    func toggleTaskProgress(lineNumber: Int) throws {
        var sections = readSections()
        let index = lineNumber - 1
        guard sections.active.indices.contains(index), let task = parseTask(line: sections.active[index], lineNumber: lineNumber) else {
            return
        }
        guard task.status == " " || task.status == ">" else {
            return
        }

        let nextStatus = task.status == ">" ? " " : ">"
        sections.active[index] = formatTask(status: nextStatus, title: task.title)
        try write(active: sections.active, archive: sections.archive)
        lastModificationDate = Self.modificationDate(for: fileURL)
    }

    func updateTask(lineNumber: Int, title: String) throws {
        let cleanTitle = normalizedTitle(title)
        guard !cleanTitle.isEmpty else {
            return
        }

        var sections = readSections()
        let index = lineNumber - 1
        guard sections.active.indices.contains(index), let task = parseTask(line: sections.active[index], lineNumber: lineNumber) else {
            return
        }

        sections.active[index] = formatTask(status: task.status, title: cleanTitle)
        try write(active: sections.active, archive: sections.archive)
        lastModificationDate = Self.modificationDate(for: fileURL)
    }

    func moveTask(lineNumber: Int, offset: Int) throws -> Int {
        var sections = readSections()
        let sourceIndex = lineNumber - 1
        let destinationIndex = sourceIndex + offset
        guard sections.active.indices.contains(sourceIndex), sections.active.indices.contains(destinationIndex) else {
            return lineNumber
        }

        let task = sections.active.remove(at: sourceIndex)
        sections.active.insert(task, at: destinationIndex)
        try write(active: sections.active, archive: sections.archive)
        lastModificationDate = Self.modificationDate(for: fileURL)
        return destinationIndex + 1
    }

    private func readSections() -> (active: [String], archive: [String]) {
        guard
            FileManager.default.fileExists(atPath: fileURL.path),
            let text = try? String(contentsOf: fileURL, encoding: .utf8)
        else {
            return ([], [])
        }

        let lines = text.split(separator: "\n", omittingEmptySubsequences: false).map(String.init)
        guard let separatorIndex = lines.firstIndex(where: { $0.trimmingCharacters(in: .whitespaces) == separator }) else {
            return (lines, [])
        }

        return (
            Array(lines[..<separatorIndex]),
            Array(lines[lines.index(after: separatorIndex)...])
        )
    }

    private func write(active: [String], archive: [String]) throws {
        var lines = active
        if !archive.isEmpty {
            lines.append(separator)
            lines.append(contentsOf: archive)
        }

        let text = lines.joined(separator: "\n") + "\n"
        try text.write(to: fileURL, atomically: true, encoding: .utf8)
    }

    private func normalizedTitle(_ title: String) -> String {
        title
            .components(separatedBy: .whitespacesAndNewlines)
            .filter { !$0.isEmpty }
            .joined(separator: " ")
    }

    private func formatTask(status: String, title: String) -> String {
        "- [\(status)] \(title)"
    }

    private func parseTask(line: String, lineNumber: Int) -> BacklogTask? {
        let pattern = #"^\s*-\s*\[(.)\]\s*(.*)$"#
        guard let regex = try? NSRegularExpression(pattern: pattern) else {
            return nil
        }

        let range = NSRange(line.startIndex..<line.endIndex, in: line)
        guard let match = regex.firstMatch(in: line, range: range), match.numberOfRanges == 3 else {
            return nil
        }

        let statusRange = Range(match.range(at: 1), in: line)
        let titleRange = Range(match.range(at: 2), in: line)

        guard let statusRange, let titleRange else {
            return nil
        }

        return BacklogTask(
            lineNumber: lineNumber,
            status: String(line[statusRange]),
            title: String(line[titleRange])
        )
    }

    private static func modificationDate(for url: URL) -> Date? {
        guard let attrs = try? FileManager.default.attributesOfItem(atPath: url.path) else {
            return nil
        }
        return attrs[.modificationDate] as? Date
    }
}

final class TaskTextView: NSTextView {
    var onCommit: (() -> Void)?
    var onCancel: (() -> Void)?

    override func keyDown(with event: NSEvent) {
        let isCommandA = event.modifierFlags.contains(.command) && event.keyCode == 0
        if isCommandA {
            selectAll(nil)
            return
        }

        let isCommandReturn = event.modifierFlags.contains(.command) && (event.keyCode == 36 || event.keyCode == 76)
        if isCommandReturn {
            onCommit?()
            return
        }

        if event.keyCode == 53 {
            onCancel?()
            return
        }

        super.keyDown(with: event)
    }
}

final class MainWindow: NSWindow {
    var onSpace: (() -> Void)?
    var onEscape: (() -> Void)?
    var onQuit: (() -> Void)?

    override func keyDown(with event: NSEvent) {
        let isPlainSpace = event.charactersIgnoringModifiers == " " && event.modifierFlags.intersection(.deviceIndependentFlagsMask).isEmpty
        if isPlainSpace {
            onSpace?()
            return
        }

        let isCommandQ = event.modifierFlags.contains(.command) && event.keyCode == 12
        if isCommandQ {
            onQuit?()
            return
        }

        if event.keyCode == 53 {
            onEscape?()
            return
        }

        super.keyDown(with: event)
    }
}

final class TaskPanel: NSPanel {
    override var canBecomeKey: Bool {
        true
    }
}

final class AppController: NSObject, NSApplicationDelegate, NSWindowDelegate, NSTableViewDataSource, NSTableViewDelegate {
    private let store = BacklogStore(fileURL: URL(fileURLWithPath: FileManager.default.currentDirectoryPath).appendingPathComponent(backlogFileName))
    private var tasks: [BacklogTask] = []
    private var viewMode = TaskViewMode.active
    private var window: NSWindow!
    private var taskScrollView: NSScrollView!
    private var tableView: NSTableView!
    private var emptyLabel: NSTextField!
    private var modalTargets: [ClosureTarget] = []
    private var keyMonitor: Any?
    private let shouldOpenAddTaskOnLaunch: Bool = {
        let args = Array(CommandLine.arguments.dropFirst())
        return args.count == 1 && ["a", "add"].contains(args[0].lowercased())
    }()
    private var timer: Timer?

    func applicationDidFinishLaunching(_ notification: Notification) {
        buildWindow()
        reloadTasks()
        if shouldOpenAddTaskOnLaunch {
            DispatchQueue.main.async { [weak self] in
                self?.addTask()
            }
        }
        keyMonitor = NSEvent.addLocalMonitorForEvents(matching: .keyDown) { [weak self] event in
            guard
                let self,
                NSApp.modalWindow == nil,
                event.window === self.window
            else {
                return event
            }

            let isCommandQ = event.modifierFlags.contains(.command) && event.keyCode == 12
            let isPlainKey = event.modifierFlags.intersection([.command, .option, .control, .shift]).isEmpty
            let isControlKey = event.modifierFlags.contains(.control) && event.modifierFlags.intersection([.command, .option, .shift]).isEmpty

            if isCommandQ {
                NSApp.terminate(nil)
            } else if isPlainKey && event.keyCode == 53 {
                NSApp.terminate(nil)
            } else if isPlainKey && event.charactersIgnoringModifiers == " " {
                self.addTask()
            } else if isPlainKey && (event.keyCode == 36 || event.keyCode == 76) {
                self.toggleSelectedTaskProgress()
            } else if isPlainKey && event.keyCode == 14 {
                self.editSelectedTask()
            } else if isControlKey && event.keyCode == 126 {
                self.moveSelectedTask(offset: -1)
            } else if isControlKey && event.keyCode == 125 {
                self.moveSelectedTask(offset: 1)
            } else {
                return event
            }
            return nil
        }

        timer = Timer.scheduledTimer(withTimeInterval: 1.0, repeats: true) { [weak self] _ in
            self?.reloadIfNeeded()
        }
    }

    func applicationWillTerminate(_ notification: Notification) {
        timer?.invalidate()
        if let keyMonitor {
            NSEvent.removeMonitor(keyMonitor)
        }
    }

    func numberOfRows(in tableView: NSTableView) -> Int {
        tasks.count
    }

    func tableView(_ tableView: NSTableView, viewFor tableColumn: NSTableColumn?, row: Int) -> NSView? {
        let identifier = tableColumn?.identifier ?? NSUserInterfaceItemIdentifier("TaskColumn")
        let cell = tableView.makeView(withIdentifier: identifier, owner: self) as? NSTableCellView ?? NSTableCellView(frame: .zero)
        let textField = cell.textField ?? NSTextField(labelWithString: "")

        cell.identifier = identifier
        cell.textField = textField
        if textField.superview == nil {
            let horizontalPadding: CGFloat = identifier.rawValue == "TaskColumn" ? 8 : 2
            textField.translatesAutoresizingMaskIntoConstraints = false
            textField.lineBreakMode = .byTruncatingTail
            textField.textColor = .labelColor
            cell.addSubview(textField)
            NSLayoutConstraint.activate([
                textField.leadingAnchor.constraint(equalTo: cell.leadingAnchor, constant: horizontalPadding),
                textField.trailingAnchor.constraint(equalTo: cell.trailingAnchor, constant: -horizontalPadding),
                textField.centerYAnchor.constraint(equalTo: cell.centerYAnchor),
            ])
        }

        let task = tasks[row]
        switch identifier.rawValue {
        case "LineColumn":
            textField.stringValue = "\(task.lineNumber)"
            textField.alignment = .center
        case "StatusColumn":
            textField.stringValue = displayStatus(task.status)
            textField.alignment = .center
        default:
            textField.stringValue = task.title
            textField.alignment = .left
        }

        return cell
    }

    private func buildWindow() {
        let frame = NSRect(x: 0, y: 0, width: 720, height: 480)
        window = MainWindow(
            contentRect: frame,
            styleMask: [.titled, .closable, .miniaturizable, .resizable],
            backing: .buffered,
            defer: false
        )
        window.title = "gbl"
        window.delegate = self
        (window as? MainWindow)?.onSpace = { [weak self] in
            self?.addTask()
        }
        (window as? MainWindow)?.onEscape = {
            NSApp.terminate(nil)
        }
        (window as? MainWindow)?.onQuit = {
            NSApp.terminate(nil)
        }
        window.center()

        let contentView = NSView(frame: frame)
        contentView.autoresizingMask = [.width, .height]
        window.contentView = contentView

        let button = NSButton(title: "Add", target: self, action: #selector(addTask))
        button.bezelStyle = .rounded
        button.frame = NSRect(x: frame.width - 96, y: frame.height - 42, width: 76, height: 28)
        button.autoresizingMask = [.minXMargin, .minYMargin]
        contentView.addSubview(button)

        taskScrollView = NSScrollView(frame: NSRect(x: 16, y: 16, width: frame.width - 32, height: frame.height - 64))
        taskScrollView.autoresizingMask = [.width, .height]
        taskScrollView.hasVerticalScroller = true
        taskScrollView.drawsBackground = true
        taskScrollView.backgroundColor = .textBackgroundColor
        contentView.addSubview(taskScrollView)

        tableView = NSTableView(frame: taskScrollView.bounds)
        tableView.autoresizingMask = [.width, .height]
        tableView.delegate = self
        tableView.dataSource = self
        tableView.headerView = nil
        tableView.rowHeight = 28
        tableView.backgroundColor = .textBackgroundColor
        tableView.usesAlternatingRowBackgroundColors = true

        addColumn(identifier: "LineColumn", title: "#", width: 28)
        addColumn(identifier: "StatusColumn", title: "Status", width: 30)
        addColumn(identifier: "TaskColumn", title: "Task", width: 520)

        taskScrollView.documentView = tableView

        emptyLabel = NSTextField(labelWithString: "Backlog Zero")
        emptyLabel.translatesAutoresizingMaskIntoConstraints = false
        emptyLabel.alignment = .center
        emptyLabel.font = .boldSystemFont(ofSize: 28)
        emptyLabel.textColor = .linkColor
        emptyLabel.toolTip = "Show completed tasks"
        emptyLabel.isHidden = true
        emptyLabel.addGestureRecognizer(NSClickGestureRecognizer(target: self, action: #selector(showCompletedTasks)))
        contentView.addSubview(emptyLabel)
        NSLayoutConstraint.activate([
            emptyLabel.centerXAnchor.constraint(equalTo: taskScrollView.centerXAnchor),
            emptyLabel.centerYAnchor.constraint(equalTo: taskScrollView.centerYAnchor),
        ])

        window.makeKeyAndOrderFront(nil)
        NSApp.activate(ignoringOtherApps: true)
    }

    func windowWillClose(_ notification: Notification) {
        NSApp.terminate(nil)
    }

    private func addColumn(identifier: String, title: String, width: CGFloat) {
        let column = NSTableColumn(identifier: NSUserInterfaceItemIdentifier(identifier))
        column.title = title
        column.width = width
        column.minWidth = width
        if identifier != "TaskColumn" {
            column.maxWidth = width
            column.resizingMask = []
        }
        tableView.addTableColumn(column)
    }

    @objc private func addTask() {
        guard let title = openTaskEditor(title: "Add Task", initialText: "") else {
            return
        }

        do {
            try store.addTask(title)
            reloadTasks()
        } catch {
            showError("Could not save backlog.md: \(error.localizedDescription)")
        }
    }

    private func editSelectedTask() {
        guard let task = selectedActiveTask(), let title = openTaskEditor(title: "Edit Task", initialText: task.title) else {
            return
        }

        do {
            try store.updateTask(lineNumber: task.lineNumber, title: title)
            reloadTasks(selectingLineNumber: task.lineNumber)
        } catch {
            showError("Could not save backlog.md: \(error.localizedDescription)")
        }
    }

    private func toggleSelectedTaskProgress() {
        guard let task = selectedActiveTask() else {
            return
        }

        do {
            try store.toggleTaskProgress(lineNumber: task.lineNumber)
            reloadTasks(selectingLineNumber: task.lineNumber)
        } catch {
            showError("Could not save backlog.md: \(error.localizedDescription)")
        }
    }

    private func moveSelectedTask(offset: Int) {
        guard let task = selectedActiveTask() else {
            return
        }

        do {
            let newLineNumber = try store.moveTask(lineNumber: task.lineNumber, offset: offset)
            reloadTasks(selectingLineNumber: newLineNumber)
        } catch {
            showError("Could not save backlog.md: \(error.localizedDescription)")
        }
    }

    private func selectedActiveTask() -> BacklogTask? {
        guard viewMode == .active, tableView.selectedRow >= 0, tasks.indices.contains(tableView.selectedRow) else {
            return nil
        }
        return tasks[tableView.selectedRow]
    }

    private func openTaskEditor(title: String, initialText: String) -> String? {
        let panel = TaskPanel(
            contentRect: NSRect(x: 0, y: 0, width: 420, height: 176),
            styleMask: [.borderless],
            backing: .buffered,
            defer: false
        )
        panel.title = title
        panel.backgroundColor = .clear
        panel.isOpaque = false
        panel.hasShadow = true
        panel.isReleasedWhenClosed = false

        let contentView = NSView(frame: panel.contentView?.bounds ?? .zero)
        contentView.autoresizingMask = [.width, .height]
        contentView.wantsLayer = true
        contentView.layer?.backgroundColor = NSColor.windowBackgroundColor.cgColor
        contentView.layer?.cornerRadius = 14
        contentView.layer?.masksToBounds = true
        panel.contentView = contentView

        let controlBar = NSView(frame: NSRect(x: 10, y: 138, width: 400, height: 24))
        controlBar.autoresizingMask = [.width, .minYMargin]
        contentView.addSubview(controlBar)

        let titleLabel = NSTextField(labelWithString: "New task")
        titleLabel.frame = NSRect(x: 0, y: 3, width: 220, height: 20)
        titleLabel.autoresizingMask = [.width]
        titleLabel.font = .systemFont(ofSize: 13, weight: .semibold)
        titleLabel.textColor = .secondaryLabelColor
        controlBar.addSubview(titleLabel)

        let cancelButton = makeIconButton(
            title: "✕",
            backgroundColor: .systemRed,
            toolTip: "Cancel",
            frame: NSRect(x: 330, y: 0, width: 30, height: 24)
        )
        cancelButton.autoresizingMask = [.minXMargin]
        controlBar.addSubview(cancelButton)

        let addButton = makeIconButton(
            title: "✓",
            backgroundColor: .systemGreen,
            toolTip: "Add",
            frame: NSRect(x: 370, y: 0, width: 30, height: 24)
        )
        addButton.autoresizingMask = [.minXMargin]
        controlBar.addSubview(addButton)

        let inputScrollView = NSScrollView(frame: NSRect(x: 10, y: 10, width: 400, height: 118))
        inputScrollView.hasVerticalScroller = true
        inputScrollView.borderType = .bezelBorder
        inputScrollView.autoresizingMask = [.width, .height]
        contentView.addSubview(inputScrollView)

        let inputTextView = TaskTextView(frame: inputScrollView.bounds)
        inputTextView.autoresizingMask = [.width, .height]
        inputTextView.isVerticallyResizable = true
        inputTextView.isHorizontallyResizable = false
        inputTextView.textContainer?.widthTracksTextView = true
        inputTextView.font = .systemFont(ofSize: NSFont.systemFontSize)
        inputTextView.string = initialText

        inputScrollView.documentView = inputTextView

        var shouldCommit = false
        let stopModal = {
            NSApp.stopModal()
        }

        let addTarget = ClosureTarget {
            shouldCommit = true
            stopModal()
        }
        addButton.target = addTarget
        addButton.action = #selector(ClosureTarget.invoke)

        let cancelTarget = ClosureTarget {
            shouldCommit = false
            stopModal()
        }
        cancelButton.target = cancelTarget
        cancelButton.action = #selector(ClosureTarget.invoke)
        modalTargets = [addTarget, cancelTarget]

        inputTextView.onCommit = {
            shouldCommit = true
            stopModal()
        }
        inputTextView.onCancel = {
            shouldCommit = false
            stopModal()
        }

        if let parentFrame = window?.frame {
            panel.setFrameOrigin(NSPoint(
                x: parentFrame.midX - panel.frame.width / 2,
                y: parentFrame.midY - panel.frame.height / 2
            ))
        } else {
            panel.center()
        }
        panel.initialFirstResponder = inputTextView
        panel.makeKeyAndOrderFront(nil)
        DispatchQueue.main.async {
            panel.makeFirstResponder(inputTextView)
        }
        NSApp.runModal(for: panel)
        panel.orderOut(nil)
        modalTargets = []

        return shouldCommit ? inputTextView.string : nil
    }

    private func makeIconButton(title: String, backgroundColor: NSColor, toolTip: String, frame: NSRect) -> NSButton {
        let button = NSButton(frame: frame)
        button.isBordered = false
        button.wantsLayer = true
        button.layer?.backgroundColor = backgroundColor.cgColor
        button.layer?.cornerRadius = 6
        button.layer?.masksToBounds = true
        button.attributedTitle = NSAttributedString(
            string: title,
            attributes: [
                .foregroundColor: NSColor.white,
                .font: NSFont.boldSystemFont(ofSize: 13),
            ]
        )
        button.toolTip = toolTip
        return button
    }

    private func reloadIfNeeded() {
        guard store.hasChanged() else {
            return
        }
        reloadTasks()
    }

    private func reloadTasks(selectingLineNumber: Int? = nil) {
        let activeTasks = store.loadActiveTasks()
        if activeTasks.isEmpty && viewMode == .completed {
            tasks = store.loadCompletedTasks()
        } else {
            viewMode = .active
            tasks = activeTasks
        }
        tableView?.reloadData()
        taskScrollView?.isHidden = tasks.isEmpty
        emptyLabel?.isHidden = !tasks.isEmpty

        if let selectingLineNumber, let row = tasks.firstIndex(where: { $0.lineNumber == selectingLineNumber }) {
            tableView?.selectRowIndexes(IndexSet(integer: row), byExtendingSelection: false)
            tableView?.scrollRowToVisible(row)
        }
    }

    @objc private func showCompletedTasks() {
        viewMode = .completed
        tasks = store.loadCompletedTasks()
        tableView?.reloadData()
        taskScrollView?.isHidden = tasks.isEmpty
        emptyLabel?.isHidden = !tasks.isEmpty
    }

    private func displayStatus(_ status: String) -> String {
        switch status {
        case " ":
            return "⬜"
        case ">":
            return "▶️"
        case "x", "X":
            return "✅"
        default:
            return status
        }
    }

    private func showError(_ message: String) {
        let alert = NSAlert()
        alert.alertStyle = .critical
        alert.messageText = "Error"
        alert.informativeText = message
        alert.runModal()
    }
}

final class ClosureTarget: NSObject {
    private let closure: () -> Void

    init(_ closure: @escaping () -> Void) {
        self.closure = closure
    }

    @objc func invoke() {
        closure()
    }
}

let app = NSApplication.shared
let delegate = AppController()
app.delegate = delegate
app.setActivationPolicy(.regular)
app.run()
